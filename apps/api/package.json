{
  "name": "@phoenix-ai/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API — serves the OKF knowledge bundle, drift reports, and the human review/correction workflow.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@phoenix-ai/shared": "workspace:*",
    "@phoenix-ai/knowledge-graph": "workspace:*",
    "@phoenix-ai/okf-renderers": "workspace:*",
    "@phoenix-ai/review-loop": "workspace:*",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.4"
  }
}
